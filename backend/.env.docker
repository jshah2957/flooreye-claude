# FloorEye v2.0 — Docker Environment Variables
ENVIRONMENT=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# MongoDB — use Docker service name
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=flooreye

# Redis — use Docker service name
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Auth
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
EDGE_SECRET_KEY=dev-edge-secret-change-in-production
EDGE_TOKEN_EXPIRE_DAYS=180

# Encryption
ENCRYPTION_KEY=ZGV2LWVuY3J5cHRpb24ta2V5LTMyLWJ5dGVz

# Storage
# LIMITATION: S3_ENDPOINT_URL points to localhost:9000 (MinIO). This won't work without
# a MinIO container running. If using docker-compose.dev.yml, MinIO is NOT included — see
# the comment block at the top of docker-compose.dev.yml for how to add it.
# For AWS S3, replace with https://s3.amazonaws.com and set real credentials.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=flooreye
S3_REGION=us-east-1
LOCAL_STORAGE_PATH=/app/data
# NOTE: LEARNING_S3_BUCKET is not in this file. It defaults to "flooreye-learning"
# (set in app/core/config.py). Override here if needed: LEARNING_S3_BUCKET=flooreye-learning

# Roboflow
# LIMITATION: ROBOFLOW_API_KEY is needed for Roboflow dataset import (capture_roboflow_dataset).
# Without it, Roboflow capture is silently skipped. Get your key from https://roboflow.com dashboard
# under Settings > API Key.
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=
ROBOFLOW_API_URL=https://detect.roboflow.com

CF_ACCOUNT_ID=
CF_API_TOKEN=
FIREBASE_CREDENTIALS_JSON=
TRAINING_WORKER_ENABLED=false
TRAINING_DATA_DIR=/app/training-data
MODELS_DIR=/app/models
SENTRY_DSN=
