# FloorEye v2.0 — Docker Environment Variables
ENVIRONMENT=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# MongoDB — use Docker service name
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=flooreye

# Redis — use Docker service name
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Auth
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
EDGE_SECRET_KEY=dev-edge-secret-change-in-production
EDGE_TOKEN_EXPIRE_DAYS=180

# Encryption
ENCRYPTION_KEY=ZGV2LWVuY3J5cHRpb24ta2V5LTMyLWJ5dGVz

# Storage
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=flooreye
S3_REGION=us-east-1
LOCAL_STORAGE_PATH=/app/data

# Roboflow
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=
ROBOFLOW_API_URL=https://detect.roboflow.com

CF_ACCOUNT_ID=
CF_API_TOKEN=
FIREBASE_CREDENTIALS_JSON=
TRAINING_WORKER_ENABLED=false
TRAINING_DATA_DIR=/app/training-data
MODELS_DIR=/app/models
SENTRY_DSN=
