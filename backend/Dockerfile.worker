# ── Stage 1: Build ──────────────────────────────────────────────
FROM python:3.11-slim AS builder

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# ── Stage 2: Production ────────���───────────────────────────────
FROM python:3.11-slim

WORKDIR /app

# System deps for OpenCV + mongodump for backup worker
# Note: [trusted=yes] used because MongoDB's GPG key uses SHA1 which Debian 12+ rejects since 2026-02
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 libglib2.0-0 ffmpeg curl \
    && echo "deb [trusted=yes] https://repo.mongodb.org/apt/debian bookworm/mongodb-org/7.0 main" > /etc/apt/sources.list.d/mongodb-org-7.0.list \
    && apt-get update && apt-get install -y --no-install-recommends mongodb-database-tools \
    && apt-get purge -y curl && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /install /usr/local

COPY . .

# Non-root user — needs /app, /app/data, /tmp/training writeable
RUN adduser --disabled-password --gecos "" appuser \
    && mkdir -p /app/data /tmp/training \
    && chown -R appuser:appuser /app /tmp/training

USER appuser

CMD ["celery", "-A", "app.workers.celery_app", "worker", "--loglevel=info", "--concurrency=2"]
