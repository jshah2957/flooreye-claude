# ===========================================
# FloorEye v2.0 — Backend Environment Variables
# Copy to .env and fill in real values
# ===========================================

# Application
ENVIRONMENT=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=flooreye

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Authentication (JWT)
SECRET_KEY=CHANGE_ME_256_BIT_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Edge Agent Auth
EDGE_SECRET_KEY=CHANGE_ME_EDGE_SECRET
EDGE_TOKEN_EXPIRE_DAYS=180

# Encryption (AES-256-GCM)
ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTE_KEY

# S3 / MinIO / R2 Storage
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=flooreye
S3_REGION=us-east-1
LOCAL_STORAGE_PATH=/app/data

# Cloudflare Tunnel
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_JSON=

# Training
TRAINING_WORKER_ENABLED=false
TRAINING_DATA_DIR=/app/training-data
MODELS_DIR=/app/models

# Sentry (optional)
SENTRY_DSN=
