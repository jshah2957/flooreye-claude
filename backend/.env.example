# ===========================================
# FloorEye v2.0 — Backend Environment Variables
# Copy to .env and fill in real values
# ===========================================

# Application
ENVIRONMENT=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=flooreye

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Authentication (JWT)
SECRET_KEY=CHANGE_ME_256_BIT_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Edge Agent Auth
EDGE_SECRET_KEY=CHANGE_ME_EDGE_SECRET
EDGE_TOKEN_EXPIRE_DAYS=180

# Encryption (AES-256-GCM)
ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTE_KEY

# S3 / MinIO / R2 Storage
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=flooreye
S3_REGION=us-east-1
LOCAL_STORAGE_PATH=/app/data

# Cloudflare Tunnel
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_JSON=

# Model Pipeline
MODELS_DIR=/app/models
LOCAL_INFERENCE_ENABLED=true
ONNX_MODEL_CACHE_DIR=/app/models

# Roboflow
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=
ROBOFLOW_API_URL=https://detect.roboflow.com
ROBOFLOW_PROJECT_ID=
ROBOFLOW_PROJECT_VERSION=0

# MongoDB Auth
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_MONGO_PASSWORD

# Redis
REDIS_PASS=CHANGE_ME_REDIS_PASSWORD

# MinIO / S3
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# Detection
DETECTION_LOG_RETENTION_DAYS=90
MONGODB_MAX_POOL_SIZE=25

# Cloudflare Tunnel Config Directory
CLOUDFLARED_CONFIG_DIR=./.cloudflared

# Sentry (optional)
SENTRY_DSN=
