# ===========================================
# FloorEye v2.0 — Edge Agent Environment Variables
# Copy to .env and fill in real values
# ===========================================

# Cloud Backend
BACKEND_URL=https://api.flooreye.example.com
EDGE_TOKEN=CHANGE_ME_EDGE_JWT

# Identity
ORG_ID=
STORE_ID=

# Cameras (comma-separated RTSP/ONVIF URLs)
CAMERA_URLS=rtsp://admin:password@192.168.1.100:554/stream1

# Capture
CAPTURE_FPS=2

# Inference
INFERENCE_MODE=hybrid
HYBRID_THRESHOLD=0.65
MAX_ESCALATIONS_PER_MIN=10
INFERENCE_SERVER_URL=http://inference-server:8080

# Upload
UPLOAD_FRAMES=wet
FRAME_SAMPLE_RATE=5

# Buffer (offline queue)
BUFFER_PATH=/data/buffer
MAX_BUFFER_GB=10
CLIPS_PATH=/data/clips

# Redis (local buffer)
REDIS_URL=redis://redis-buffer:6379/0

# Cloudflare Tunnel
TUNNEL_TOKEN=

# MQTT (optional — for device control)
MQTT_BROKER=
MQTT_USERNAME=
MQTT_PASSWORD=

# Logging
LOG_LEVEL=INFO
