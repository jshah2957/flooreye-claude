# ===========================================
# FloorEye v2.0 — Edge Agent Environment Variables
# Copy to .env and fill in real values
# ===========================================

# Cloud Backend
BACKEND_URL=https://api.flooreye.example.com
EDGE_TOKEN=CHANGE_ME_EDGE_JWT

# Identity
AGENT_ID=
ORG_ID=
STORE_ID=

# Cameras (DEPRECATED — use edge web UI at port 8090 instead)
# Only used for backward compat: auto-imported to cameras.json on first run
# CAMERA_URLS=cam1=rtsp://admin:pass@192.168.1.100/stream,cam2=rtsp://...

# Capture (default FPS, can be overridden per camera from cloud)
CAPTURE_FPS=2

# Inference
INFERENCE_SERVER_URL=http://inference-server:8080
MODEL_SOURCE=local_onnx
MODEL_CHECK_INTERVAL=3600
BATCH_INFERENCE=true
MAX_CONCURRENT_INFERENCES=4
ONNX_INPUT_SIZE=640
NMS_IOU_THRESHOLD=0.5
MAX_DETECTIONS_PER_FRAME=20

# Upload
UPLOAD_FRAMES=wet,uncertain
FRAME_SAMPLE_RATE=5

# JPEG Quality (0-100)
ANNOTATED_JPEG_QUALITY=90
CLEAN_JPEG_QUALITY=90
CAPTURE_JPEG_QUALITY=85

# Storage
BUFFER_PATH=/data/buffer
MAX_BUFFER_GB=10
CLIPS_PATH=/data/clips
DATA_PATH=/data
CONFIG_DIR=/data/config

# Retention (auto-cleanup)
FRAME_RETENTION_DAYS=30
CLIP_RETENTION_DAYS=90
CLEANUP_INTERVAL_HOURS=6
DISK_EMERGENCY_THRESHOLD=85
EMERGENCY_RETENTION_DAYS=7

# Validator
VALIDATOR_MAX_HISTORY=20

# Redis (local buffer)
REDIS_URL=redis://redis-buffer:6379/0

# Cloudflare Tunnel
TUNNEL_TOKEN=

# MQTT (optional — or use edge web UI to add devices)
MQTT_BROKER=
MQTT_USERNAME=
MQTT_PASSWORD=

# TP-Link (DEPRECATED — use edge web UI instead)
# TPLINK_DEVICES=sign1=192.168.1.50,sign2=192.168.1.51

# Ports (change if defaults conflict with other services)
WEB_UI_PORT=8090
CONFIG_RECEIVER_PORT=8091

# Timing (all values in seconds)
TPLINK_AUTO_OFF_SECONDS=600
DEFAULT_COOLDOWN_SECONDS=300
MAX_UPLOADS_PER_MIN=10
MAX_CONSECUTIVE_422=3
UPLOAD_BACKOFF_SECONDS=60
UPLOAD_MAX_RETRIES=3
COMMAND_POLL_INTERVAL=30
BUFFER_FLUSH_INTERVAL=30
HEARTBEAT_INTERVAL=30
VALIDATION_SYNC_INTERVAL=300
TPLINK_CHECK_INTERVAL=30

# Auto-clip recording on detection
AUTO_CLIP_ON_DETECTION=false
AUTO_CLIP_DURATION_SECONDS=30
AUTO_CLIP_PRE_BUFFER_SECONDS=5

# Frame sharing (include clean frames in uploads)
SHARE_CLEAN_FRAMES=true

# Logging
LOG_LEVEL=INFO
